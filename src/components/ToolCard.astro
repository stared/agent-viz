---
import type { CollectionEntry } from 'astro:content';

interface Props {
  tool: CollectionEntry<'tools'>['data'];
  tierColor: string;
}
const { tool, tierColor } = Astro.props;

// Resolve local (public/) screenshots against the configured base path;
// leave absolute http(s) URLs untouched.
const base = import.meta.env.BASE_URL;
const imgSrc = tool.image
  ? tool.image.startsWith('http')
    ? tool.image
    : base.replace(/\/$/, '') + tool.image
  : undefined;
---

<article class="card" style={`--tier-color:${tierColor}`}>
  {
    imgSrc && (
      <div class="thumb">
        <img
          src={imgSrc}
          alt={tool.imageAlt ?? tool.name}
          loading="lazy"
          decoding="async"
          onerror="this.closest('.thumb').remove()"
        />
      </div>
    )
  }
  <div class="body">
    <h3>{tool.name}</h3>
    <p class="tagline">{tool.tagline}</p>
    <p class="note">{tool.note}</p>
    <div class="links">
      {
        tool.links.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer">
            {l.label}
          </a>
        ))
      }
    </div>
  </div>
</article>
